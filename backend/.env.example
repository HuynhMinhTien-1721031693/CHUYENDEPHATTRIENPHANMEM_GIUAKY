# Đặt file này thành `.env` trong cùng thư mục `backend/`.
# Backend đọc tự động khi chạy (thư viện dotenv).

# Phiên đăng nhập
SESSION_SECRET=thay-bang-chuoi-ngau-nhien-dai
FRONTEND_URL=http://localhost:5173

# Tài khoản mặc định (chỉ tạo lần đầu nếu email chưa tồn tại trong data/app-data.json)
# Quản lý hệ thống — chỉnh cấu hình site; KHÔNG quản phòng live
SEED_SYSMANAGER_EMAIL=sys@local.test
SEED_SYSMANAGER_PASSWORD=QuanLyHT@Demo2026

# Admin phòng live — quản lý phòng/host/viewer; KHÔNG chỉnh cấu hình hệ thống như trên
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=AdminLive@Demo2026

# Bật cookie Secure khi chạy HTTPS
# COOKIE_SECURE=1
